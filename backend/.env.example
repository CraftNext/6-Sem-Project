# Copy to .env and fill in real values. NEVER commit the real .env.

# Server
PORT=5000
CLIENT_URL=http://localhost:5500

# MongoDB connection string
# (Rotate the old one — it was committed to git history and is compromised.)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/craftnext

# JWT signing secret — use a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace_with_a_long_random_secret

# Gmail for sending OTP emails — use a Gmail App Password, not your account password
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_16_char_app_password

# Google Gemini API key(s) for the AI assistant chatbox (free tier) — get at aistudio.google.com/apikey
# Comma-separated for multiple keys — requests round-robin and fall back on rate limits
GEMINI_API_KEYS=your_gemini_api_key

# Secret required to bootstrap the first admin via POST /api/admin/seed-admin
SEED_SECRET=replace_with_a_random_seed_secret
